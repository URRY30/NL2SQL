APP_NAME=NL2SQL Data Agent v2
APP_HOST=127.0.0.1
APP_PORT=8010
APP_DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/postgres
DB_SCHEMA=public

DEFAULT_TOPIC_ID=talent
# First run sql/init_talent_ai_query_views_v2.sql, then enable all views below.
ALLOWED_QUERY_VIEWS=vw_talent_ai_query,vw_talent_review_ai_query,vw_talent_education_ai_query,vw_talent_career_ai_query,vw_talent_project_ai_query,vw_talent_tag_ai_query,vw_succession_ai_query,vw_org_position_ai_query
SQL_MAX_LIMIT=100
SQL_TIMEOUT_SECONDS=20

LLM_PROVIDER=dashscope
BIGMODEL_API_KEY=replace-with-your-key
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
BIGMODEL_MODEL=glm-5.1
BIGMODEL_TIMEOUT=30
BIGMODEL_TEMPERATURE=0.1

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=60
OLLAMA_TEMPERATURE=0.1

DASHSCOPE_API_KEY=replace-with-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-plus
DASHSCOPE_TIMEOUT=60
DASHSCOPE_TEMPERATURE=0.1
DASHSCOPE_ENABLE_THINKING=true
